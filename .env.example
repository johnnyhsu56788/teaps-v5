# TEAPS v5 - Docker Environment Variables Template

# Copy this file to .env and fill in your values
# DO NOT commit the actual .env file with real secrets!

# ==================== DATABASE CONFIGURATION ====================

# MySQL Root Password (REQUIRED)
TEAPS_DB_PASSWORD=your_secure_root_password_here

# MySQL User Password (REQUIRED)
TEAPS_DB_USER_PASSWORD=your_user_password_here

# Database Host (default: mysql - internal Docker network)
TEAPS_DB_HOST=mysql

# Database Port (default: 3306)
TEAPS_DB_PORT=3306

# Database Name (default: teaps_v5)
TEAPS_DB_NAME=teaps_v5

# Database User (default: teaps_user)
TEAPS_DB_USER=teaps_user

# ==================== TELEGRAM BOT CONFIGURATION ====================

# Telegram Bot Token (REQUIRED - get from @BotFather)
# Format: 123456789:ABCdefGHIjklMNOpqrsTUVwxyz
TEAPS_TELEGRAM_BOT_TOKEN=your_bot_token_here

# ==================== QR CODE CONFIGURATION (OPTIONAL) ====================

# QR Code Secret Key for signing (auto-generated if not set)
# If you want a persistent key, set it here
QR_SECRET_KEY=optional_custom_secret_key

# ==================== WEB SERVER CONFIGURATION ====================

# Web Server Host (0.0.0.0 = listen on all interfaces)
TEAPS_WEB_HOST=0.0.0.0

# Web Server Port (default: 8000)
TEAPS_WEB_PORT=8000

# ==================== DEVELOPMENT SETTINGS ====================

# Debug Mode (true/false) - Set to false in production
DEBUG=false

# Log Level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# ==================== OPTIONAL: Nginx SSL CONFIGURATION ====================

# Domain name for HTTPS (used by nginx.conf)
NGINX_DOMAIN=your-domain.com

# SSL Certificate Path (relative to /etc/nginx/ssl/)
SSL_CERT_PATH=/path/to/fullchain.pem
SSL_KEY_PATH=/path/to/privkey.pem

# ==================== SECURITY NOTES ====================

# 1. NEVER commit .env file with real secrets to version control!
# 2. Use strong passwords (min 16 characters, mixed case + numbers + symbols)
# 3. Rotate database passwords regularly
# 4. Keep Telegram bot token secret - revoke if exposed
# 5. In production, use environment variables from a secrets manager

# Example of generating secure passwords:
# MySQL Root Password: openssl rand -base64 32
# Bot Token: Get from https://t.me/BotFather
# QR Secret: openssl rand -hex 32
